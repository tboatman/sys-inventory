---
# Copy this file to hosts.yml (gitignored) and fill in your own site's
# values. One host per LPAR you want to inventory; running the playbooks
# against the whole "zos" group inventories every LPAR listed here in one
# `ansible-playbook` invocation.

all:
  children:
    zos:
      hosts:
        lpar1:
          ansible_host: lpar1.example.com
      vars:
        # zos-extract/README.md's "Before you start" section covers what
        # each of these needs and how to get it from your admin.
        ansible_user: youruserid
        # Plain ssh -- ibm.ibm_zos_core shipped a zos_ssh connection plugin
        # in older releases, but it was removed (per its own CHANGELOG:
        # "you must remove all playbook references to connection
        # ibm.ibm_zos_core.zos_ssh"); its modules work over a normal ssh
        # connection now.
        ansible_connection: ssh
        ansible_ssh_common_args: ""
        # Path to IBM Open Enterprise Python on the target LPAR (the same
        # one `python3 --version` resolves to in your OMVS shell).
        ansible_python_interpreter: /shrd/cyp/pyz/bin/python3

        # --- what to inventory on this LPAR ---
        # Both PROCLIB and PARMLIB can be auto-discovered live (via JES2's
        # '$D PROCLIB' and 'D PARMLIB' respectively) -- leave
        # zos_extract_proclibs/zos_extract_parmlibs unset/empty (remove
        # the blocks below) to have the role query the live concatenation
        # itself instead of hand-listing it here (see
        # roles/zos_extract/tasks/discover_proclib.yml and
        # discover_parmlib.yml). An explicit list here always wins over
        # auto-discovery. PROCLIB discovery is JES2-specific (JES3 sites
        # haven't been verified against it) -- configure it by hand if
        # your site is JES3 or the discovery doesn't find anything.
        zos_extract_proclibs:
          - dsn: SYS1.PROCLIB
            prefix: "00"
        zos_extract_parmlibs:
          - dsn: SYS1.PARMLIB
            prefix: "00"

        # A list of CSIs, each with its own target/dlib zones -- a real
        # site can have several (its own product CSIs alongside the base
        # z/OS one), so this is a list even for a single-CSI site.
        zos_extract_smpe_csis:
          - csi: YOUR.GLOBAL.CSI
            zones:
              - TZONE1
        # zos_extract_smpe_steplib: YOUR.SMPE.LINKLIB   # only if GIMSMP isn't in LNKLST

        # Don't know your CSI's name(s) yet? The 'smpe_csi_discovery' tag
        # searches the catalog for candidates (naming-heuristic only, not
        # authoritative -- see roles/zos_extract/tasks/discover_smpe_csis.yml)
        # and writes them to smpe_csi_candidates.txt instead of
        # hand-configuring zos_extract_smpe_csis above. Defaults to
        # "EDUC.**.CSI" (roles/zos_extract/defaults/main.yml) since that's
        # this site's convention; override here if yours differs (e.g.
        # "SMPE.*.CSI"). Once you know a CSI's name but not its zones, the
        # 'smpe_zone_discovery' tag runs LIST GLOBALZONE against every CSI
        # already listed above and writes each one's real zone census to
        # *.smpzones.txt (see roles/zos_extract/tasks/discover_smpe_zones.yml)
        # -- `inventory zone-index` shows what it found.
        # zos_extract_smpe_csi_search_patterns:
        #   - "SMPE.*.CSI"

        # Live "what's running" CICS discovery (tag 'cics' -- see
        # roles/zos_extract/tasks/cics.yml) -- defaults to this site's
        # actual CICS job-name conventions (CTS*, ECB2*, MTSEDUC*) in
        # roles/zos_extract/defaults/main.yml; override here if a
        # particular LPAR's conventions differ.
        # zos_extract_cics_job_patterns:
        #   - "CTS*"
        #   - "ECB2*"
        #   - "MTSEDUC*"

        # Live "what's running" DB2 discovery (tag 'db2' -- see
        # roles/zos_extract/tasks/db2.yml) -- defaults to this site's
        # actual DB2 job-name convention (DB2*) in
        # roles/zos_extract/defaults/main.yml; override here if a
        # particular LPAR's convention differs.
        # zos_extract_db2_job_patterns:
        #   - "DB2*"

        zos_extract_catalog_patterns:
          - "PROD.*"
          - "PROD.**"

        # Uncomment only once you have a READ-accessible RACF database
        # COPY and have confirmed authorization with your security team --
        # see zos-extract/README.md step 10. Leave unset to skip RACF
        # entirely (it's implementation-only / not yet production-validated
        # anyway, and the racf tag is skipped by default).
        # zos_extract_racf_database_dsn: YOURHLQ.RACF.COPY
